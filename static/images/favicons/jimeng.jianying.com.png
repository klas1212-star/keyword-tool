odel_req_key":"high_aes_general_v30l_art_fangzhou:general_v3.0_18b","is_new_model":false,"sample_steps":{"steps":16,"min_steps":10,"max_steps":41},"blend_enable":{"face_swap":false,"bg_paint":false,"canny":false,"depth":false,"pose":false},"feats":["default_scene","etta","t2i","byte_edit","byte_edit_with_custom_ratio","byte_edit_with_empty_prompt"],"model_name":"图片 3.1","model_tip":"丰富的美学多样性，画面更鲜明生动","feature_key":"","generation_category_name_starling_key":"dreamina_app_modalswitch_image_3_1","generation_category_name":"图片・3.1 ","duration_option":null,"lens_motion_type_option":null,"motion_speed_option":null,"camera_strength_option":null,"video_aspect_ratio_option":null,"fps":0,"feat_config":{"canny":{"strength":0.6},"depth":{"strength":0.6},"pose":{"strength":0.6},"style_reference":{"strength":0.8}},"extra":{"model_source":"by Seedream 3.0","raw_model_source":"Seedream 3.0"},"feats_cant_combine":[["byte_edit","byte_edit"]],"model_bg_prompt_starling_key":"","resolution_map":{"1k":{"image_ratio_sizes":[{"ratio_type":1,"width":1328,"height":1328},{"ratio_type":2,"width":1104,"height":1472},{"ratio_type":3,"width":1664,"height":936},{"ratio_type":4,"width":1472,"height":1104},{"ratio_type":5,"width":936,"height":1664},{"ratio_type":6,"width":1056,"height":1584},{"ratio_type":7,"width":1584,"height":1056},{"ratio_type":8,"width":2016,"height":864}],"image_range_config":{"min_length":512,"max_length":2016,"max_pixel_num":1763584},"resolution_name":"标清 1K"},"2k":{"image_ratio_sizes":[{"ratio_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1813303245\u0026x-signature=zC0ZnbChw8vMjPQPwKoNIhlqj88%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"以水墨为表现形式，画面中巨大的孙悟空，形象占据了大部分空间，展现出震撼的巨物效果。融入丰富的国风色彩，色彩搭配和谐且富有冲击力，再利用水墨的工笔技法。采用仰视的角度，从下往上看，气势磅礴，压迫感十足，抽象的氛围营造出一种超凡脱俗的境界。肖像的精密线条，以单线连续线条绘画，让木炭在纸上游走成即兴的排线，他的线条时而密集，时而疏朗，构筑立体感，层层叠叠，这些看似无序的线条轨迹，最终重构出古典巴洛克风格与极繁主义叙事。\n拟人国风雕，神秘感，华丽炫酷的花纹和质感、冷色调，整个画面散发出一种美轮美奂的诡异气质，惊艳迷人却又令人感觉到危险和恐惧，极致的细节刻画，极致的立体纹理，奢华、繁琐、恢弘、大气，超高清画质。神话孙悟空、正脸。","seed":372684954,"large_image_info":{"height":1664,"width":936,"resolution_type":"1k"},"sample_strength":0.5,"use_pe":true,"schedule_conf":"base","actual_prompt":"以水墨为表现形式，画面中巨大的孙悟空，形象占据了大部分空间，展现出震撼的巨物效果。融入丰富的国风色彩，色彩搭配和谐且富有冲击力，再利用水墨的工笔技法。采用仰视的角度，从下往上看，气势磅礴，压迫感十足，抽象的氛围营造出一种超凡脱俗的境界。肖像的精密线条，以单线连续线条绘画，让木炭在纸上游走成即兴的排线，他的线条时而密集，时而疏朗，构筑立体感，层层叠叠，这些看似无序的线条轨迹，最终重构出古典巴洛克风格与极繁主义叙事。\n拟人国风雕，神秘感，华丽炫酷的花纹和质感、冷色调，整个画面散发出一种美轮美奂的诡异气质，惊艳迷人却又令人感觉到危险和恐惧，极致的细节刻画，极致的立体纹理，奢华、繁琐、恢弘、大气，超高清画质。神话孙悟空、正脸。","model_rewritten_prompt":"国风插画，新工笔，水墨晕染，仰视视角，巨大孙悟空正脸，占据大部分画面，气势磅礴。由王振鹏创作的新工笔作品，精细线条，单线连绵，木炭在纸上游走，即兴排线，线条时而密集时而疏朗，层次叠进，古典巴洛克与极繁主义结合。光影淡雅，冷色调，华丽炫酷的花纹和质感，美轮美奂的诡异气质，水墨技法，宣纸，水墨晕染，留白，氛围神秘，压迫感，超高清画质，极致细节刻画，极致立体纹理，奢华、繁琐、恢弘、大气。"},"template_id":"7607450898851188018","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false},"statistic":{"usage_num":145,"favorite_num":742,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7607450898851188018","effect_id":"7607450898851188018","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/1f809207e5a7414d86224b648677689b~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1813303247\u0026x-signature=sHhUE3nQsByIzS1V2C9B2IkaCcA%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":""},"author":{"name":"MoneyHair","avatar_url":"https://p6-faceu-img-sign.byteimg