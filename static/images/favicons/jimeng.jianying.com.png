560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7603692848059288858","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"照片级写实3D动画渲染风格，清晨森林场景，深绿色调，柔光处理，晨雾弥漫。地面覆盖青色苔藓，表面布满晶莹剔透的水珠，雨丝细密飘落。一只毛茸茸的白色和灰色相间的肥胖精灵，圆头圆脑，大眼睛闪烁着光芒，双手捧着一片超大的树叶作为雨伞，树叶边缘微微上翘，遮挡住精灵的身体。精灵的毛发蓬松柔软，细节丰富，水珠在毛发上滚动。中景视角，聚焦精灵和苔藓，背景虚化，增强空间感。湿润质感，清新氛围，童话般的梦幻感。","image_type":3},"statistic":{"usage_num":77,"favorite_num":310,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7603692848059288858","effect_id":"7603692848059288858","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/1e353dfd652249e19accc109a2572933~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1813303247\u0026x-signature=eDnnh7%2Bz7QLKWTiB6ucXDvjW3lA%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":""},"author":{"name":"星屿","avatar_url":"https://p6-faceu-img-sign.byteimg.com/tos-cn-i-tb4s082cfz/f3690675b4c14b3b81fcfc7f5aa2271c~tplv-resize:200:200.webp?lk3s=4eecb9e8\u0026x-expires=1784359247\u0026x-signature=ABwiiCRWM4AMzcg6DjzEpFcvM3o%3D","uid":"2865779929003244","sec_uid":"MS4wLjABAAAA1lxtVE5hxtkMefAnDqBTcBY59aOb7S057k0sGMxDBffVdrFBFZQ5lYlghl1hQLvH","description":"番台含雾星辰满，仙桥浮空岛屿微","has_followed":false,"followed_req_uid":false,"status":0,"account_type":0},"feature":"","extra":{"template_type":"image","ai_feature":"text_generate_image"}},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/9440466033164","content":"{\"type\":\"draft\",\"id\":\"14d3bb72-bc49-42b7-8876-faaac7195c82\",\"min_version\":\"3.0.2\",\"min_features\":[],\"is_from_tsn\":true,\"version\":\"3.0.2\",\"main_component_id\":\"aea6672b-0b31-460f-832f-38a0c22b549a\",\"component_list\":[{\"type\":\"image_base_component\",\"id\":\"aea6672b-0b31-460f-832f-38a0c22b549a\",\"min_version\":\"3.0.2\",\"aigc_mode\":\"workbench\",\"gen_type\":1,\"metadata\":{\"type