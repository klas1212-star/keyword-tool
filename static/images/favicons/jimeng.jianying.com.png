":{"canny":{"strength":0.6},"depth":{"strength":0.6},"pose":{"strength":0.6},"style_reference":{"strength":0.8}},"extra":{"model_source":"by Seedream 4.7","raw_model_source":"Seedream 4.3 Design"},"feats_cant_combine":[],"model_bg_prompt_starling_key":"","resolution_map":{"2k":{"image_ratio_sizes":[{"ratio_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1813303245\u0026x-signature=zC0ZnbChw8vMjPQPwKoNIhlqj88%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"莫奈风格，梵高作品，伦勃朗画作，金箔岩彩画，完美融入摄影技法+油画技法+3D技法，绿白色氛围感高级艺术海报。极简主义、抽象表达、现代设计、高级感、柔和渐变。画面采用暖色调（不同色阶的绿白色为主），绿白色的朦胧质感，隐约看到茉莉花形态。动感模糊，颜色饱满，朦胧美学。整体风格文艺雅致，富有香氛氛围感，突出诗意与意韵。细闪，细致笔触，极繁主义，超多细节，极繁风格，Octane渲染，64K高清画质，用流动的毛笔手绘字体：“Don’t wait for inspiration”（纤细的笔画，笔画拉丝，灵动的曲线，有质感），极小的装饰性小字，极细无衬线小字体“202X”，白色极细无衬线字体水印\"LUOBOS\"+\"INSPIRATION\"+\"AIGC\"+\"Every great idea begins with a spark\"，质感，肌理感，梦幻的，耀变，反射，艺术抽象，诗意的，高级，杰作，极具视觉冲击力，获奖作品，大师级配色，大师级排版，高细节，高级感，超高清，布局协调。","sample_steps":16,"large_image_info":{"height":2496,"width":1664,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"0","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"莫奈风格、梵高笔触、伦勃朗光影的金箔岩彩画，融合摄影写实、油画肌理、3D建模，绿白色渐变背景中漂浮半透明茉莉花轮廓，暖色调色阶过渡自然，动感模糊处理花瓣边缘，金箔颗粒闪烁微光，岩彩厚涂质感叠加Octane渲染的耀变反射效果。画面中央流动毛笔手写体\"Don’t wait for inspiration\"，笔画纤细拉丝、曲线灵动，右下角极细无衬线字体\"202X\"，底部透明水印\"LUOBOS\"+\"INSPIRATION\"+\"AIGC\"+\"Every great idea begins with a spark\"，整体采用极简主义构图，抽象艺术表达，现代设计排版，细闪颗粒与细致笔触交织，极繁细节堆砌，64K超高清画质，文艺雅致香氛氛围，诗意意韵流动，大师级配色与光影布局，获奖作品级视觉冲击力。","image_type":3},"statistic":{"usage_num":36,"favorite_num":694,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/13530931322892","content":"{\"type\":\"draft\",\"id\":\"ca377fe3-0b71-872d-2a62-816dce4006cf\",\"min_version\":\"3.0.2\",\"min_features\":[],\"is_from_tsn\":true,\"version\":\"3.0.2\",\"main_component_id\":\"3b18a1b5-13ae-6d96-1d29-e51e5414c320\",\"component_list\":[{\"type\":\"image_base_component\",\"id\":\"3b18a1b5-13ae-6d96-1d29-e51e5414c320\",\"min_version\":\"3.0.2\",\"aigc_mode\":\"workbench\",\"gen_type\":1,\"metadata\":{\"type\":\"\",\"id\":\"d459449a-a4db-00ed-42af-ba25ed86e11d\",\"created_platform\":3,\"created_platform_version\":\"\",\"created_time_in_ms\":\"1779765014068\",\"created_did\":\"\"},\"generate_type\":\"generate\",\"abilities\":{\"type\":\"\",\"id\":\"ce608d09-6ca9-2cff-9a0d-2a6e38c9fb18\",\"generate\":{\"type\":\"\",\"id\":\"8f0acfc3-4f44-1cee-0335-40a9f07cb022\",\"core_param\":{\"type\":\"\",\"id\":\"5e6f7bef-1664-da26-4e7d-f436af55d4dc\",\"model\":\"high_aes_general_v43\",\"prompt\":\"莫奈风格，梵高作品，伦勃朗画作，金箔岩彩画，完美融入摄影技法+油画技法+3D技法，绿白色氛围感高级艺术海报。极简主义、抽象表达、现代设计、高级感、柔和渐变。画面采用暖色调（不同色阶的绿白色为主），绿白色的朦胧质感，隐约看到茉莉花形态。动感模糊，颜色饱满，朦胧美学。整体风格文艺雅致，富有香氛氛围感，突出诗意与意韵。细闪，细致笔触，极繁主义，超多细节，极繁风格，Octane渲染，64K高清画质，用流动的毛笔手绘字体：“Don’t wait for inspiration”（纤细的笔画，笔画拉丝，灵动的曲线，有质感），极小的装饰性小字，极细无衬线小字体“202X”，白色极细无衬线字体水印\\\"LUOBOS\\\"+\\\"INSPIRATION\\\"+\\\"AIGC\\\"+\\\"Every great idea begins with a spark\\\"，质感，肌理感，梦幻的，耀变，反射，艺术抽象，诗意的，高级，杰作，极具视觉冲击力，获奖作品，大师级配色，大师级排版，高细节，高级感，超高清，布局协调。\",\"negative_prompt\":\"\",\"seed\":1589759864,\"sample_strength\":0.5,\"image_ratio\":6,\"large_image_info\":{\"type\":\"\",\"id\":\"8ebfcd48-c0e9-4e27-79d4-5fb2deee2a2c\",\"height\":2496,\"width\":1664,\"resolution_type\":\"2k\"},\"intelligent_ratio\":false,\"generate_type\":0}},\"gen_option\":{\"type\":\"\",\"id\":\"0118acf6-cc54-c5c2-312e-