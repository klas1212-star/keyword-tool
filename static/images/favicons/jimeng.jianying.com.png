mage?lk3s=8e790bc3\u0026x-expires=1813303245\u0026x-signature=zC0ZnbChw8vMjPQPwKoNIhlqj88%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"一幅极致厚涂的插画特写，聚焦于一只橘猫的头部。画面以凌厉锋利的流线型笔触构建出强烈的动态与琉璃般的晶莹质感。猫咪拥有一张精致无瑕的面庞，双色异瞳（一只是琥珀黄，一则是翡翠绿）在垂眸间流泻出混合了张扬、冷酷、忧郁与高傲的复杂情绪。它一身蓬松的长毛被处理得极致细腻，凌乱而富有生命力的发束，一副银丝眼镜链随意垂落，与根根分明、锐利如刀的长睫毛相映成趣。整体色调为低饱和度，通过柔光与流体笔触的叠加，营造出一种既朦胧梦幻又充满锋利线条的视觉冲突，仿佛定格于现实与幻想的边界。","sample_steps":25,"seed":1693162274,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7611726102318435634","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"极致厚涂插画特写，聚焦橘猫头部，凌厉流线型笔触构建动态，琉璃晶莹质感。猫咪面庞精致无瑕，双色异瞳（琥珀黄与翡翠绿）垂眸流露张扬、冷酷、忧郁、高傲复杂情绪。蓬松长毛细腻，凌乱发束富有生命力，银丝眼镜链随意垂落，与锐利长睫毛相映成趣。低饱和度色调，柔光与流体笔触叠加，营造朦胧梦幻与锋利线条的视觉冲突，现实与幻想边界氛围。","image_type":3},"statistic":{"usage_num":14,"favorite_num":249,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7611726102318435634","effect_id":"7611726102318435634","effect_type":9,"description":"","cover_url":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/89080b6f4397416f86709f9da315bf04~tplv-tb4s082cfz-aigc_resize:640:640.png?lk3s=4fa96020\u0026x-expires=1813303247\u0026x-signature=DzCZZ8XctfLWSNYcBd594bpLOHM%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":"猫猫"},"author":{"name":"曾建国","avatar_url":"https://p9-passport.byteacctimg.com/img/user-avatar/9eaef939b4e03602a178bf9b60defb48~300x300.image","uid":"1922399233381662","sec_uid":"MS4wLjABAAAAIh0QQmvMV7fI6K0VsIYY_Bl90dGBLAmWlIhCUG02Lc9QS2u_lCgynTSTAH-A2kXM","description":"。","has_followed":false,"followed_req_uid":false,"status":0,"account_type":0},"feature":"","extra":{"template_type":"image","ai_feature":"text_generate_image"}},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/9174309294092","content":"{\"type\":\"draft\",\"id\":\"288ee0d4-6f98-4407-b592-eea211c635de\",\"min_version\":\"3.0.2\",\"min_features\"